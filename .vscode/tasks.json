{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build",
            "type": "process",
            "command": "dotnet",
            "args": [
                "build",
                "${workspaceFolder}/StemForge.slnx",
                "/consoleloggerparameters:NoSummary;ForceNoAlign"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "silent",
                "panel": "shared",
                "clear": true
            },
            "problemMatcher": "$msCompile"
        },
        {
            "label": "run",
            "type": "process",
            "command": "dotnet",
            "args": [
                "run",
                "--project",
                "${workspaceFolder}/src/StemForge/StemForge.csproj"
            ],
            "group": {
                "kind": "test",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "clear": true
            },
            "problemMatcher": "$msCompile"
        },
        {
            "label": "run: No tools",
            "type": "process",
            "command": "dotnet",
            "args": [
                "run",
                "--project",
                "${workspaceFolder}/src/StemForge/StemForge.csproj",
                "--launch-profile",
                "No tools"
            ],
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "clear": true
            },
            "problemMatcher": "$msCompile"
        },
        {
            "label": "run: No uv",
            "type": "process",
            "command": "dotnet",
            "args": [
                "run",
                "--project",
                "${workspaceFolder}/src/StemForge/StemForge.csproj",
                "--launch-profile",
                "No uv"
            ],
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "clear": true
            },
            "problemMatcher": "$msCompile"
        },
        {
            "label": "watch",
            "type": "process",
            "command": "dotnet",
            "args": [
                "watch",
                "--project",
                "${workspaceFolder}/src/StemForge/StemForge.csproj",
                "run"
            ],
            "isBackground": true,
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": {
                "base": "$msCompile",
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": "^.*dotnet watch.*Started",
                    "endsPattern": "^.*dotnet watch.*(Exited|Waiting for a file to change)"
                }
            }
        },
        {
            "label": "clean",
            "type": "process",
            "command": "dotnet",
            "args": ["clean", "${workspaceFolder}/StemForge.slnx"],
            "presentation": {
                "reveal": "silent",
                "panel": "shared",
                "clear": true
            },
            "problemMatcher": "$msCompile"
        },
        {
            "label": "restore",
            "type": "process",
            "command": "dotnet",
            "args": ["restore", "${workspaceFolder}/StemForge.slnx"],
            "presentation": {
                "reveal": "silent",
                "panel": "shared",
                "clear": true
            },
            "problemMatcher": "$msCompile"
        },
        {
            "label": "test",
            "type": "process",
            "command": "dotnet",
            "args": [
                "test",
                "${workspaceFolder}/src/StemForge.Tests/StemForge.Tests.csproj"
            ],
            "group": "test",
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "clear": true
            },
            "problemMatcher": "$msCompile"
        },
        {
            "label": "test: coverage report",
            "type": "shell",
            "command": "dotnet tool run dotnet-coverage collect --output ${workspaceFolder}/src/StemForge.Tests/TestResults/coverage.cobertura.xml --output-format cobertura --settings ${workspaceFolder}/coverage.settings.xml -- dotnet test ${workspaceFolder}/src/StemForge.Tests/StemForge.Tests.csproj && (Get-Content '${workspaceFolder}/src/StemForge.Tests/TestResults/coverage.cobertura.xml' -Raw) -replace '<packages>', '<sources><source>${workspaceFolder}</source></sources><packages>' | Set-Content '${workspaceFolder}/src/StemForge.Tests/TestResults/coverage.cobertura.xml' && dotnet reportgenerator -reports:${workspaceFolder}/src/StemForge.Tests/TestResults/coverage.cobertura.xml -targetdir:${workspaceFolder}/src/StemForge.Tests/TestResults/report -reporttypes:Html -assemblyfilters:+StemForge -filefilters:-*obj* && start ${workspaceFolder}/src/StemForge.Tests/TestResults/report/index.html",
            "group": "test",
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "clear": true
            },
            "problemMatcher": "$msCompile"
        },
        {
            "label": "publish: win-x64 (self-contained)",
            "type": "process",
            "command": "dotnet",
            "args": [
                "publish",
                "${workspaceFolder}/src/StemForge/StemForge.csproj",
                "--runtime",
                "win-x64",
                "--self-contained",
                "true",
                "--configuration",
                "Release",
                "--output",
                "${workspaceFolder}/publish/win-x64",
                "-p:PublishSingleFile=true",
                "-p:PublishReadyToRun=true",
                "-p:UseAppHost=true",
                "-p:IncludeNativeLibrariesForSelfExtract=true"
            ],
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "clear": true
            },
            "problemMatcher": "$msCompile"
        }
    ]
}
