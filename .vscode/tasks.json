{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build",
            "type": "process",
            "command": "dotnet",
            "args": [
                "build",
                "${workspaceFolder}/StemForge.slnx",
                "/consoleloggerparameters:NoSummary;ForceNoAlign"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "silent",
                "panel": "shared",
                "clear": true
            },
            "problemMatcher": "$msCompile"
        },
        {
            "label": "run",
            "type": "process",
            "command": "dotnet",
            "args": [
                "run",
                "--project",
                "${workspaceFolder}/src/StemForge/StemForge.csproj"
            ],
            "group": {
                "kind": "test",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "clear": true
            },
            "problemMatcher": "$msCompile"
        },
        {
            "label": "watch",
            "type": "process",
            "command": "dotnet",
            "args": [
                "watch",
                "--project",
                "${workspaceFolder}/src/StemForge/StemForge.csproj",
                "run"
            ],
            "isBackground": true,
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": {
                "base": "$msCompile",
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": "^.*dotnet watch.*Started",
                    "endsPattern": "^.*dotnet watch.*(Exited|Waiting for a file to change)"
                }
            }
        },
        {
            "label": "clean",
            "type": "process",
            "command": "dotnet",
            "args": ["clean", "${workspaceFolder}/StemForge.slnx"],
            "presentation": {
                "reveal": "silent",
                "panel": "shared",
                "clear": true
            },
            "problemMatcher": "$msCompile"
        },
        {
            "label": "restore",
            "type": "process",
            "command": "dotnet",
            "args": ["restore", "${workspaceFolder}/StemForge.slnx"],
            "presentation": {
                "reveal": "silent",
                "panel": "shared",
                "clear": true
            },
            "problemMatcher": "$msCompile"
        },
        {
            "label": "test",
            "type": "process",
            "command": "dotnet",
            "args": [
                "test",
                "${workspaceFolder}/src/StemForge.Tests/StemForge.Tests.csproj"
            ],
            "group": "test",
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "clear": true
            },
            "problemMatcher": "$msCompile"
        },
        {
            "label": "test: coverage report",
            "type": "shell",
            "command": "dotnet tool run dotnet-coverage collect --output ${workspaceFolder}/src/StemForge.Tests/TestResults/coverage.cobertura.xml --output-format cobertura --settings ${workspaceFolder}/coverage.settings.xml -- dotnet test ${workspaceFolder}/src/StemForge.Tests/StemForge.Tests.csproj && (Get-Content '${workspaceFolder}/src/StemForge.Tests/TestResults/coverage.cobertura.xml' -Raw) -replace '<packages>', '<sources><source>${workspaceFolder}</source></sources><packages>' | Set-Content '${workspaceFolder}/src/StemForge.Tests/TestResults/coverage.cobertura.xml' && dotnet reportgenerator -reports:${workspaceFolder}/src/StemForge.Tests/TestResults/coverage.cobertura.xml -targetdir:${workspaceFolder}/src/StemForge.Tests/TestResults/report -reporttypes:Html -assemblyfilters:+StemForge -filefilters:-*obj* && start ${workspaceFolder}/src/StemForge.Tests/TestResults/report/index.html",
            "group": "test",
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "clear": true
            },
            "problemMatcher": "$msCompile"
        },
        {
            "label": "publish: win-x64 GUI",
            "detail": "Publish the GUI as a self-contained single-file executable to publish/win-x64/.",
            "type": "process",
            "command": "dotnet",
            "args": [
                "publish",
                "${workspaceFolder}/src/StemForge/StemForge.csproj",
                "--runtime",
                "win-x64",
                "--self-contained",
                "true",
                "--configuration",
                "Release",
                "--output",
                "${workspaceFolder}/publish/win-x64",
                "-p:PublishSingleFile=true",
                "-p:IncludeNativeLibrariesForSelfExtract=true",
                "-p:PublishReadyToRun=true",
                "-p:DebugType=embedded"
            ],
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "clear": true
            },
            "problemMatcher": "$msCompile"
        },
        {
            "label": "publish: win-x64 CLI",
            "detail": "Publish the CLI as a self-contained single-file executable into publish/win-x64/.",
            "type": "process",
            "command": "dotnet",
            "args": [
                "publish",
                "${workspaceFolder}/src/StemForge.Cli/StemForge.Cli.csproj",
                "--runtime",
                "win-x64",
                "--self-contained",
                "true",
                "--configuration",
                "Release",
                "--output",
                "${workspaceFolder}/publish/win-x64",
                "-p:PublishSingleFile=true",
                "-p:IncludeNativeLibrariesForSelfExtract=true",
                "-p:PublishReadyToRun=true",
                "-p:DebugType=embedded"
            ],
            "dependsOn": "publish: win-x64 GUI",
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "clear": true
            },
            "problemMatcher": "$msCompile"
        },
        {
            "label": "package: win-x64",
            "detail": "Stage the full publish/win-x64/ folder under StemForge/ and produce StemForge-v{Version}-win-x64.zip in publish/. Reads <Version> from StemForge.csproj.",
            "type": "process",
            "command": "pwsh",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-Command",
                "$ErrorActionPreference='Stop'; $root='${workspaceFolder}'; $publish=\"$root/publish/win-x64\"; $stage=\"$root/publish/stage\"; $version=(Select-Xml -Path \"$root/src/StemForge/StemForge.csproj\" -XPath '//Version').Node.InnerText; $zip=\"$root/publish/StemForge-v$version-win-x64.zip\"; if (Test-Path $stage) { Remove-Item $stage -Recurse -Force }; New-Item -ItemType Directory -Path \"$stage/StemForge\" -Force | Out-Null; Copy-Item \"$publish/*\" \"$stage/StemForge/\" -Recurse; if (Test-Path $zip) { Remove-Item $zip }; Compress-Archive -Path \"$stage/StemForge\" -DestinationPath $zip -CompressionLevel Optimal; \"Created: $zip ($([math]::Round((Get-Item $zip).Length / 1MB, 1)) MB)\""
            ],
            "dependsOn": "publish: win-x64 CLI",
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "clear": true
            },
            "problemMatcher": []
        }
    ]
}
