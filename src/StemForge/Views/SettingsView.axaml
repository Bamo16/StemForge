<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:StemForge.ViewModels"
             xmlns:ext="using:StemForge.Extensions"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="1044" d:DesignHeight="720"
             x:Class="StemForge.Views.SettingsView"
             x:DataType="vm:SettingsViewModel">

    <UserControl.Styles>
        <!-- Section heading -->
        <Style Selector="TextBlock.settingSection">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="Margin" Value="0,0,0,10" />
        </Style>

        <!-- Setting row label -->
        <Style Selector="TextBlock.settingLabel">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,0,0,6" />
        </Style>

        <!-- Settings TextBox -->
        <Style Selector="TextBox.settingInput">
            <Setter Property="Background" Value="{DynamicResource Bg0Brush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Bg3Brush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="FontFamily" Value="{DynamicResource MonoFont}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        </Style>

        <!-- Card panel -->
        <Style Selector="Border.card">
            <Setter Property="Background" Value="{DynamicResource Bg0Brush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Bg3Brush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="16,14" />
        </Style>

        <!-- GPU variant toggle button -->
        <Style Selector="Button.variantTab">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Bg3Brush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="14,7" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="Medium" />
        </Style>
        <Style Selector="Button.variantTab.active">
            <Setter Property="Background" Value="{DynamicResource AccentDimBgBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
        </Style>
        <Style Selector="Button.variantTab:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource Bg2Brush}" />
        </Style>

        <!-- Tool status dot -->
        <Style Selector="Ellipse.statusDot">
            <Setter Property="Width" Value="7" />
            <Setter Property="Height" Value="7" />
        </Style>
        <Style Selector="Ellipse.statusDot.ok">
            <Setter Property="Fill" Value="{DynamicResource SuccessBrush}" />
        </Style>
        <Style Selector="Ellipse.statusDot.fail">
            <Setter Property="Fill" Value="{DynamicResource ErrorBrush}" />
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="50,*">

        <!-- ===== Toolbar ===== -->
        <Border Grid.Row="0"
                Background="{DynamicResource Bg1Brush}"
                BorderBrush="{DynamicResource Bg3Brush}"
                BorderThickness="0,0,0,1"
                Padding="20,0">
            <TextBlock Classes="h1" Text="{Binding Title}" VerticalAlignment="Center" />
        </Border>

        <!-- ===== Scrollable content (max 600px centered) ===== -->
        <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Disabled">
            <StackPanel MaxWidth="600"
                        HorizontalAlignment="Center"
                        Margin="20,24,20,40"
                        Spacing="20">

                <!-- ── Status banner ── always visible; contents swap on ToolsLoading -->
                <Border CornerRadius="10" BorderThickness="1">
                    <Border.Background>
                        <SolidColorBrush Color="{DynamicResource SuccessColor}" Opacity="0.08" />
                    </Border.Background>
                    <Border.BorderBrush>
                        <SolidColorBrush Color="{DynamicResource SuccessColor}" Opacity="0.3" />
                    </Border.BorderBrush>

                    <Panel>
                        <!-- Loading state -->
                        <StackPanel IsVisible="{Binding ToolsLoading}"
                                    Spacing="10" Margin="16,14">
                            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                <Ellipse Width="7" Height="7">
                                    <Ellipse.Fill>
                                        <SolidColorBrush Color="{DynamicResource SuccessColor}" Opacity="0.5" />
                                    </Ellipse.Fill>
                                </Ellipse>
                                <TextBlock Text="Detecting tools…"
                                           FontSize="12" FontWeight="Bold" LetterSpacing="0.06"
                                           Foreground="{DynamicResource TextSecondaryBrush}" />
                            </StackPanel>
                            <ProgressBar IsIndeterminate="True"
                                         Height="2"
                                         Foreground="{DynamicResource SuccessBrush}"
                                         Background="Transparent" />
                        </StackPanel>

                        <!-- Done state -->
                        <StackPanel IsVisible="{Binding !ToolsLoading}"
                                    Spacing="12" Margin="16,14">
                            <!-- Header -->
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Ellipse Classes="statusDot" Classes.ok="{Binding AllSystemsGo}"
                                         Classes.fail="{Binding !AllSystemsGo}" />
                                <TextBlock FontSize="12" FontWeight="Bold" LetterSpacing="0.06"
                                           Foreground="{DynamicResource SuccessBrush}"
                                           Text="ALL SYSTEMS GO"
                                           IsVisible="{Binding AllSystemsGo}" />
                                <TextBlock FontSize="12" FontWeight="Bold" LetterSpacing="0.06"
                                           Foreground="{DynamicResource ErrorBrush}"
                                           Text="MISSING REQUIRED TOOLS"
                                           IsVisible="{Binding !AllSystemsGo}" />
                            </StackPanel>
                            <!-- Tool rows -->
                            <ItemsControl ItemsSource="{Binding Tools}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Spacing="10" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="vm:ToolStatusViewModel">
                                        <StackPanel Spacing="2">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <Ellipse Classes="statusDot"
                                                         Classes.ok="{Binding Found}"
                                                         Classes.fail="{Binding !Found}"
                                                         VerticalAlignment="Center" />
                                                <TextBlock Text="{Binding Name}"
                                                           FontSize="11" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                                           VerticalAlignment="Center" />
                                                <Border IsVisible="{Binding VariantTag, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                                        Background="{DynamicResource AccentDimBgBrush}"
                                                        CornerRadius="3" Padding="4,1"
                                                        VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding VariantTag}"
                                                               FontSize="9" FontWeight="SemiBold"
                                                               Foreground="{DynamicResource AccentBrush}" />
                                                </Border>
                                            </StackPanel>
                                            <TextBlock Classes="mono"
                                                       Text="{Binding StatusLine}"
                                                       FontSize="11"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       Margin="13,0,0,0" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <Button Classes="ghost"
                                        Content="Refresh"
                                        Command="{Binding RefreshToolsCommand}" />
                                <Button Classes="ghost"
                                        Content="Re-run setup wizard"
                                        Command="{Binding ShowWizardCommand}" />
                            </StackPanel>
                        </StackPanel>
                    </Panel>
                </Border>

                <!-- ── audio-separator ── -->
                <StackPanel Spacing="12">
                    <TextBlock Classes="settingSection" Text="audio-separator" />
                    <Border Classes="card">
                        <StackPanel Spacing="14">
                            <!-- Installed status -->
                            <StackPanel IsVisible="{Binding IsAudioSeparatorInstalled}" Spacing="6">
                                <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                    <TextBlock FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                                               Text="Installed:" VerticalAlignment="Center" />
                                    <Border Background="{DynamicResource AccentDimBgBrush}"
                                            CornerRadius="3" Padding="6,1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding InstalledVariantLabel}"
                                                   FontSize="11" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource AccentBrush}" />
                                    </Border>
                                </StackPanel>
                                <TextBlock FontSize="11"
                                           Foreground="{DynamicResource TextPlaceholderBrush}"
                                           Text="The variant determines whether audio-separator runs on CPU, NVIDIA CUDA, or Windows DirectML. Change it if you swap GPU hardware."
                                           TextWrapping="Wrap" />
                                <TextBlock FontSize="11" FontWeight="Medium"
                                           Foreground="{DynamicResource AccentBrush}"
                                           Text="{Binding GpuHint}"
                                           IsVisible="{Binding GpuHint, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />

                                <!-- Action buttons (hidden while a manage action is in progress) -->
                                <StackPanel Orientation="Horizontal" Spacing="8"
                                            IsVisible="{Binding !IsManagingTool}">
                                    <Button Classes="ghost" Content="Change variant…"
                                            Command="{Binding BeginChangeVariantCommand}" />
                                    <Button Classes="ghost" Content="Reinstall"
                                            Command="{Binding BeginReinstallCommand}" />
                                    <Button Classes="ghost" Content="Uninstall"
                                            Foreground="{DynamicResource ErrorBrush}"
                                            BorderBrush="{DynamicResource ErrorBrush}"
                                            Command="{Binding BeginUninstallCommand}" />
                                </StackPanel>

                                <!-- Change-variant panel -->
                                <Border IsVisible="{Binding IsChangeVariantOpen}"
                                        Background="{DynamicResource Bg1Brush}"
                                        BorderBrush="{DynamicResource Bg3Brush}"
                                        BorderThickness="1" CornerRadius="6" Padding="12">
                                    <StackPanel Spacing="10">
                                        <TextBlock FontSize="12" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   Text="Pick a variant to switch to" />
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <Button Classes="variantTab"
                                                    Classes.active="{Binding IsPendingCpu}"
                                                    Command="{Binding SetPendingVariantCommand}"
                                                    CommandParameter="Cpu" Content="CPU" />
                                            <Button Classes="variantTab"
                                                    Classes.active="{Binding IsPendingCuda}"
                                                    Command="{Binding SetPendingVariantCommand}"
                                                    CommandParameter="Cuda" Content="CUDA" />
                                            <Button Classes="variantTab"
                                                    Classes.active="{Binding IsPendingDirectML}"
                                                    Command="{Binding SetPendingVariantCommand}"
                                                    CommandParameter="DirectML" Content="DirectML" />
                                        </StackPanel>
                                        <TextBlock FontSize="11" TextWrapping="Wrap"
                                                   Foreground="{DynamicResource TextPlaceholderBrush}"
                                                   Text="Switching variants will reinstall audio-separator. This can take a few minutes." />
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <Button Classes="accent" Content="Confirm reinstall"
                                                    Command="{Binding ConfirmChangeVariantCommand}" />
                                            <Button Classes="ghost" Content="Cancel"
                                                    Command="{Binding CancelManageCommand}" />
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <!-- Reinstall confirm -->
                                <Border IsVisible="{Binding IsReinstallConfirmOpen}"
                                        Background="{DynamicResource Bg1Brush}"
                                        BorderBrush="{DynamicResource Bg3Brush}"
                                        BorderThickness="1" CornerRadius="6" Padding="12">
                                    <StackPanel Spacing="10">
                                        <TextBlock FontSize="12" TextWrapping="Wrap"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   Text="Reinstall audio-separator with the current variant? This can take a few minutes." />
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <Button Classes="accent" Content="Reinstall"
                                                    Command="{Binding ConfirmReinstallCommand}" />
                                            <Button Classes="ghost" Content="Cancel"
                                                    Command="{Binding CancelManageCommand}" />
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <!-- Uninstall confirm -->
                                <Border IsVisible="{Binding IsUninstallConfirmOpen}"
                                        Background="{DynamicResource Bg1Brush}"
                                        BorderBrush="{DynamicResource Bg3Brush}"
                                        BorderThickness="1" CornerRadius="6" Padding="12">
                                    <StackPanel Spacing="10">
                                        <TextBlock FontSize="12" TextWrapping="Wrap"
                                                   Foreground="{DynamicResource ErrorBrush}"
                                                   Text="Uninstall audio-separator? StemForge will be unable to run separations until you reinstall it." />
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <Button Classes="accent" Content="Uninstall"
                                                    Foreground="{DynamicResource ErrorBrush}"
                                                    Command="{Binding ConfirmUninstallCommand}" />
                                            <Button Classes="ghost" Content="Cancel"
                                                    Command="{Binding CancelManageCommand}" />
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <!-- In-progress + log -->
                                <Border IsVisible="{Binding IsManagingTool}"
                                        Background="{DynamicResource Bg1Brush}"
                                        BorderBrush="{DynamicResource Bg3Brush}"
                                        BorderThickness="1" CornerRadius="6" Padding="12">
                                    <StackPanel Spacing="8">
                                        <TextBlock FontSize="12" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   Text="{Binding ManageStatus}" />
                                        <ProgressBar IsIndeterminate="True" Height="2"
                                                     Foreground="{DynamicResource AccentBrush}"
                                                     Background="Transparent" />
                                        <ScrollViewer MaxHeight="120"
                                                      HorizontalScrollBarVisibility="Disabled"
                                                      ext:ScrollViewerExtensions.AutoScrollToEnd="True"
                                                      IsVisible="{Binding ManageLog, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                            <SelectableTextBlock Classes="mono"
                                                                 Text="{Binding ManageLog}"
                                                                 FontSize="10"
                                                                 Foreground="{DynamicResource TextPlaceholderBrush}"
                                                                 TextWrapping="Wrap" />
                                        </ScrollViewer>
                                    </StackPanel>
                                </Border>

                                <!-- Error message -->
                                <Border IsVisible="{Binding ManageError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                        Background="{DynamicResource ErrorDimBgBrush}"
                                        CornerRadius="6" Padding="12">
                                    <TextBlock FontSize="12" TextWrapping="Wrap"
                                               Foreground="{DynamicResource ErrorBrush}"
                                               Text="{Binding ManageError}" />
                                </Border>
                            </StackPanel>

                            <!-- Not installed: prompt to run setup wizard -->
                            <StackPanel IsVisible="{Binding !IsAudioSeparatorInstalled}" Spacing="6">
                                <TextBlock FontSize="12"
                                           Foreground="{DynamicResource ErrorBrush}"
                                           Text="audio-separator is not installed." />
                                <TextBlock FontSize="11" TextWrapping="Wrap"
                                           Foreground="{DynamicResource TextPlaceholderBrush}"
                                           Text="Run the setup wizard to install it." />
                                <Button Classes="ghost" Content="Re-run setup wizard"
                                        Command="{Binding ShowWizardCommand}"
                                        HorizontalAlignment="Left" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- ── Tool paths ── -->
                <StackPanel Spacing="12">
                    <TextBlock Classes="settingSection" Text="Tool paths" />
                    <Border Classes="card">
                        <StackPanel Spacing="14">
                            <TextBlock FontSize="11" TextWrapping="Wrap"
                                       Foreground="{DynamicResource TextPlaceholderBrush}"
                                       Text="Override which binary StemForge invokes for each tool. Leave blank to use StemForge's default discovery — described per-field below." />
                            <StackPanel Spacing="6">
                                <TextBlock Classes="settingLabel" Text="uv" />
                                <TextBox Classes="settingInput"
                                         Text="{Binding UvPath, Mode=TwoWay}"
                                         PlaceholderText="Default: 'uv' on PATH" />
                            </StackPanel>
                            <StackPanel Spacing="6">
                                <TextBlock Classes="settingLabel" Text="audio-separator" />
                                <TextBox Classes="settingInput"
                                         Text="{Binding AudioSeparatorPath, Mode=TwoWay}"
                                         PlaceholderText="Default: uv-installed shim, falls back to 'audio-separator' on PATH" />
                            </StackPanel>
                            <StackPanel Spacing="6">
                                <TextBlock Classes="settingLabel" Text="yt-dlp" />
                                <TextBox Classes="settingInput"
                                         Text="{Binding YtdlpPath, Mode=TwoWay}"
                                         PlaceholderText="Default: 'yt-dlp' on PATH (typically uv-installed shim)" />
                            </StackPanel>
                            <StackPanel Spacing="6">
                                <TextBlock Classes="settingLabel" Text="ffmpeg" />
                                <TextBox Classes="settingInput"
                                         Text="{Binding FfmpegPath, Mode=TwoWay}"
                                         PlaceholderText="Default: bundled binary in %LOCALAPPDATA%\StemForge\bin, falls back to 'ffmpeg' on PATH" />
                            </StackPanel>
                            <StackPanel Spacing="6">
                                <TextBlock Classes="settingLabel" Text="deno" />
                                <TextBox Classes="settingInput"
                                         Text="{Binding DenoPath, Mode=TwoWay}"
                                         PlaceholderText="Default: bundled binary in %LOCALAPPDATA%\StemForge\bin, falls back to 'deno' on PATH" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- ── yt-dlp ── -->
                <StackPanel Spacing="12">
                    <TextBlock Classes="settingSection" Text="yt-dlp" />
                    <Border Classes="card">
                        <StackPanel Spacing="14">
                            <StackPanel Spacing="6">
                                <TextBlock Classes="settingLabel"
                                           Text="Cookies from browser (e.g. firefox, chrome, edge)" />
                                <TextBox Classes="settingInput"
                                         Text="{Binding YtdlpCookiesFromBrowser, Mode=TwoWay}"
                                         PlaceholderText="Leave blank to skip" />
                                <TextBlock FontSize="11" TextWrapping="Wrap"
                                           Foreground="{DynamicResource TextPlaceholderBrush}"
                                           Text="Needed for YouTube Premium audio (up to 264 kbps opus vs ~135 kbps without). Alternatively, export a cookies.txt file from your browser using the &quot;Get cookies.txt LOCALLY&quot; extension and enter its path instead." />
                                <HyperlinkButton Padding="0" FontSize="11"
                                                 NavigateUri="https://github.com/yt-dlp/yt-dlp/wiki/FAQ#how-do-i-pass-cookies-to-yt-dlp"
                                                 Foreground="{DynamicResource AccentBrush}"
                                                 Content="yt-dlp cookie documentation ↗" />
                            </StackPanel>
                            <StackPanel Spacing="6">
                                <TextBlock Classes="settingLabel"
                                           Text="Default download format" />
                                <ComboBox ItemsSource="{Binding AudioFormatOptions}"
                                          SelectedItem="{Binding DefaultAudioFormat, Mode=TwoWay}"
                                          MinWidth="120" />
                                <TextBlock FontSize="11" TextWrapping="Wrap"
                                           Foreground="{DynamicResource TextPlaceholderBrush}"
                                           Text="FLAC: lossless. WAV: lossless 24-bit, larger files. MP3: lossy 320 kbps, smallest." />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- ── Defaults ── -->
                <StackPanel Spacing="12">
                    <TextBlock Classes="settingSection" Text="Default directories" />
                    <Border Classes="card">
                        <StackPanel Spacing="14">
                            <!-- Output dir -->
                            <StackPanel Spacing="6">
                                <TextBlock Classes="settingLabel" Text="Output directory" />
                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                    <TextBox Grid.Column="0" Classes="settingInput"
                                             Text="{Binding OutputDirectory, Mode=TwoWay}" />
                                    <Button Grid.Column="1" Classes="ghost"
                                            Content="Browse"
                                            Click="OnBrowseOutputClicked" />
                                </Grid>
                            </StackPanel>
                            <!-- Models dir -->
                            <StackPanel Spacing="6">
                                <TextBlock Classes="settingLabel" Text="Models directory" />
                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                    <TextBox Grid.Column="0" Classes="settingInput"
                                             Text="{Binding ModelsDirectory, Mode=TwoWay}" />
                                    <Button Grid.Column="1" Classes="ghost"
                                            Content="Browse"
                                            Click="OnBrowseModelsClicked" />
                                </Grid>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- ── Drum extraction ── -->
                <StackPanel Spacing="12">
                    <TextBlock Classes="settingSection" Text="Drum extraction" />
                    <Border Classes="card">
                        <StackPanel Spacing="14">
                            <StackPanel Spacing="6">
                                <TextBlock Classes="settingLabel" Text="Model" />
                                <TextBox Classes="settingInput"
                                         Text="{Binding DrumExtractionModel, Mode=TwoWay}"
                                         PlaceholderText="htdemucs_ft.yaml" />
                                <TextBlock FontSize="11" TextWrapping="Wrap"
                                           Foreground="{DynamicResource TextPlaceholderBrush}"
                                           Text="audio-separator model used for drum stem extraction. Leave blank to use the default." />
                            </StackPanel>
                            <CheckBox IsChecked="{Binding DrumStemsWithOutputs, Mode=TwoWay}"
                                      Content="Write drum stem alongside other output files"
                                      FontSize="12" />
                            <TextBlock FontSize="11" TextWrapping="Wrap"
                                       Foreground="{DynamicResource TextPlaceholderBrush}"
                                       Text="When unchecked, the drum stem is cached internally and not shown in the output folder. Useful if drums are only needed for BPM detection (coming soon)." />
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- ── Save footer ── -->
                <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="12">
                    <TextBlock Grid.Column="1"
                               Text="✓  Saved"
                               FontSize="12"
                               Foreground="{DynamicResource SuccessBrush}"
                               VerticalAlignment="Center"
                               IsVisible="{Binding SaveSuccess}" />
                    <Button Grid.Column="2"
                            Classes="accent"
                            Content="Save changes"
                            Command="{Binding SaveCommand}" />
                </Grid>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
