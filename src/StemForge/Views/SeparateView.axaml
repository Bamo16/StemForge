<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:StemForge.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="1044" d:DesignHeight="720"
             x:Class="StemForge.Views.SeparateView"
             x:DataType="vm:SeparateViewModel">

    <UserControl.Styles>
        <!-- ===== Mode toggle pill ===== -->
        <Style Selector="Border.modePillHost">
            <Setter Property="Background" Value="{DynamicResource Bg0Brush}" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="2" />
        </Style>
        <Style Selector="Button.modeTab">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource TextPlaceholderBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Padding" Value="14,5" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="Medium" />
        </Style>
        <Style Selector="Button.modeTab.active">
            <Setter Property="Background" Value="{DynamicResource Bg2Brush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        </Style>

        <!-- ===== Drop zone ===== -->
        <Style Selector="Border.dropZone">
            <Setter Property="BorderBrush" Value="{DynamicResource Bg3Brush}" />
            <Setter Property="BorderThickness" Value="1.5" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Height" Value="52" />
            <Setter Property="Background" Value="Transparent" />
        </Style>
        <Style Selector="Border.dropZone:pointerover">
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
            <Setter Property="Background" Value="{DynamicResource AccentDimBgBrush}" />
        </Style>
        <Style Selector="Border.dropZone.disabled">
            <Setter Property="Opacity" Value="0.45" />
        </Style>
        <Style Selector="Border.dropZone.disabled:pointerover">
            <Setter Property="BorderBrush" Value="{DynamicResource Bg3Brush}" />
            <Setter Property="Background" Value="Transparent" />
        </Style>

        <!-- ===== URL input field ===== -->
        <Style Selector="Border.urlField">
            <Setter Property="Background" Value="{DynamicResource Bg0Brush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Bg3Brush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Height" Value="52" />
            <Setter Property="Padding" Value="12,0" />
        </Style>
        <Style Selector="Border.urlField:focus-within">
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
        </Style>
        <Style Selector="Border.urlField.urlDisabled">
            <Setter Property="Opacity" Value="0.45" />
        </Style>
        <Style Selector="Border.urlField TextBox">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="FontFamily" Value="{DynamicResource MonoFont}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style Selector="Border.urlField TextBox /template/ Border">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>
        <Style Selector="Border.urlField TextBox:pointerover /template/ Border">
            <Setter Property="Background" Value="Transparent" />
        </Style>
        <Style Selector="Border.urlField TextBox:focus /template/ Border">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
        </Style>

        <!-- ===== Preset card ===== -->
        <Style Selector="Border.preset">
            <Setter Property="Background" Value="{DynamicResource Bg0Brush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Bg3Brush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="BorderBrush" Duration="0:0:0.15" />
                    <BrushTransition Property="Background" Duration="0:0:0.15" />
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Border.preset:pointerover">
            <Setter Property="BorderBrush" Value="{DynamicResource TextPlaceholderBrush}" />
        </Style>
        <Style Selector="Border.preset.selected">
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
            <Setter Property="Background" Value="{DynamicResource AccentDimBgBrush}" />
        </Style>

        <!-- Checkbox inside preset card -->
        <Style Selector="Border.checkbox">
            <Setter Property="Width" Value="16" />
            <Setter Property="Height" Value="16" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="BorderBrush" Value="{DynamicResource Bg3Brush}" />
            <Setter Property="BorderThickness" Value="1.5" />
            <Setter Property="Margin" Value="0,1,0,0" />
            <Setter Property="VerticalAlignment" Value="Top" />
        </Style>
        <Style Selector="Border.preset.selected Border.checkbox">
            <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
        </Style>

        <!-- Preset name/description color shifts when selected -->
        <Style Selector="Border.preset TextBlock.presetName">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style Selector="Border.preset.selected TextBlock.presetName">
            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
        </Style>

        <!-- Tag chip -->
        <Style Selector="Border.tag">
            <Setter Property="Background" Value="{DynamicResource Bg2Brush}" />
            <Setter Property="CornerRadius" Value="3" />
            <Setter Property="Padding" Value="6,2" />
        </Style>
        <Style Selector="Border.tag TextBlock">
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontFamily" Value="{DynamicResource MonoFont}" />
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
        </Style>

        <!-- Format picker row -->
        <Style Selector="Border.fmtRow">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Padding" Value="6,4" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style Selector="Border.fmtRow:pointerover">
            <Setter Property="Background" Value="{DynamicResource AccentDimBgBrush}" />
        </Style>
        <Style Selector="Border.fmtRow.selected">
            <Setter Property="Background" Value="{DynamicResource AccentMedBgBrush}" />
        </Style>
        <Style Selector="Border.fmtRow.selected:pointerover">
            <Setter Property="Background" Value="{DynamicResource AccentMedBgBrush}" />
        </Style>


        <!-- Format picker toggle link -->
        <Style Selector="Button.fmtToggle">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Padding" Value="0,2" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style Selector="Button.fmtToggle:pointerover /template/ ContentPresenter">
            <Setter Property="TextBlock.Foreground" Value="{DynamicResource AccentBrightBrush}" />
        </Style>

        <!-- Tooltip skin consistent with the app's dark palette -->
        <Style Selector="ToolTip">
            <Setter Property="Background" Value="{DynamicResource Bg1Brush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Bg3Brush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
        </Style>
    </UserControl.Styles>

    <!-- Row heights mirror tokens in Styles/Tokens.axaml: ToolbarHeight=50, FooterBarHeight=56. -->
    <Grid RowDefinitions="50,Auto,*,56">

        <!-- ===== Toolbar ===== -->
        <Border Grid.Row="0"
                Background="{DynamicResource Bg1Brush}"
                BorderBrush="{DynamicResource Bg3Brush}"
                BorderThickness="0,0,0,1"
                Padding="20,0">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0"
                           Classes="h1"
                           Text="{Binding Title}"
                           VerticalAlignment="Center" />
                <Border Grid.Column="1" Classes="modePillHost" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="1">
                        <Button Classes="modeTab"
                                Classes.active="{Binding IsBuiltInMode}"
                                Command="{Binding SetModeCommand}"
                                CommandParameter="BuiltIn"
                                Content="Built-in" />
                        <Button Classes="modeTab"
                                Classes.active="{Binding IsMyPresetsMode}"
                                Command="{Binding SetModeCommand}"
                                CommandParameter="MyPresets"
                                Content="My Presets" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- ===== Input bar ===== -->
        <Border Grid.Row="1"
                Background="{DynamicResource Bg1Brush}"
                BorderBrush="{DynamicResource Bg3Brush}"
                BorderThickness="0,0,0,1"
                Padding="20,12">
            <Grid ColumnDefinitions="*,Auto,1.2*" ColumnSpacing="12">

                <!-- Drop zone column: zone + inline blocked-message stack -->
                <StackPanel Grid.Column="0" Spacing="6">
                    <Border Classes="dropZone"
                            Classes.disabled="{Binding !IsLocalInputEnabled}"
                            IsEnabled="{Binding IsLocalInputEnabled}"
                            x:Name="DropZone"
                            DragDrop.AllowDrop="True"
                            PointerPressed="OnDropZoneClicked">
                        <Panel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <!-- Empty state -->
                            <StackPanel Orientation="Horizontal" Spacing="10"
                                        IsVisible="{Binding !HasInputFile}">
                                <Path Data="M8 2 V10 M5 7 L8 10 L11 7 M2 11 V13 A1 1 0 0 0 3 14 H13 A1 1 0 0 0 14 13 V11"
                                      Width="16" Height="16" Stretch="None"
                                      Stroke="{DynamicResource TextSecondaryBrush}" StrokeThickness="1.5"
                                      StrokeLineCap="Round" StrokeJoin="Round" />
                                <TextBlock VerticalAlignment="Center" FontSize="13"
                                           Foreground="{DynamicResource TextSecondaryBrush}">
                                    <Run Text="Drop audio file, or " />
                                    <Run Text="browse" Foreground="{DynamicResource AccentBrush}" />
                                </TextBlock>
                            </StackPanel>
                            <!-- File selected state -->
                            <StackPanel Orientation="Horizontal" Spacing="8"
                                        IsVisible="{Binding HasInputFile}">
                                <TextBlock Classes="mono"
                                           Text="{Binding InputFileName}"
                                           FontSize="12"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           VerticalAlignment="Center" />
                                <Button Classes="ghost"
                                        Content="×"
                                        Command="{Binding ClearInputCommand}"
                                        FontSize="16"
                                        Padding="4,0"
                                        VerticalAlignment="Center" />
                            </StackPanel>
                        </Panel>
                    </Border>
                    <!-- Local file chips row -->
                    <StackPanel Orientation="Horizontal" Spacing="6"
                                IsVisible="{Binding ShowLocalChips}">
                        <Border Classes="tag" IsVisible="{Binding HasLocalCodec}">
                            <TextBlock Text="{Binding LocalCodec}" />
                        </Border>
                        <Border Classes="tag" IsVisible="{Binding HasLocalBitrate}">
                            <TextBlock Text="{Binding LocalBitrate}" />
                        </Border>
                        <Border Classes="tag" IsVisible="{Binding HasLocalSampleRate}">
                            <TextBlock Text="{Binding LocalSampleRate}" />
                        </Border>
                        <Border Classes="tag" IsVisible="{Binding HasLocalDuration}">
                            <TextBlock Text="{Binding LocalDuration}" />
                        </Border>
                    </StackPanel>
                    <!-- Inline blocked message + wizard link -->
                    <StackPanel Orientation="Horizontal" Spacing="6"
                                IsVisible="{Binding ShowLocalBlockedMessage}">
                        <TextBlock Text="{Binding LocalInputBlockedMessage}"
                                   FontSize="11"
                                   Foreground="{DynamicResource ErrorBrush}"
                                   VerticalAlignment="Center"
                                   TextWrapping="Wrap" />
                        <Button Classes="fmtToggle"
                                Content="Re-run setup wizard"
                                Command="{Binding ShowWizardCommand}" />
                    </StackPanel>
                </StackPanel>

                <TextBlock Grid.Column="1" Text="or"
                           FontSize="12"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           VerticalAlignment="Center" />

                <!-- URL field -->
                <StackPanel Grid.Column="2" x:Name="UrlColumnStack" Spacing="6">
                    <Border Classes="urlField"
                            Classes.urlDisabled="{Binding !IsUrlInputEnabled}"
                            IsEnabled="{Binding IsUrlInputEnabled}">
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                            <Path Grid.Column="0"
                                  Data="M5.5 8.5 L8.5 5.5 M6.5 4.5 L7.8 3.2 A2.5 2.5 0 0 1 11.34 6.74 L10 8.1 M4 5.9 L2.66 7.26 A2.5 2.5 0 0 0 6.2 10.8 L7.5 9.5"
                                  Width="14" Height="14" Stretch="None"
                                  Stroke="{DynamicResource TextSecondaryBrush}" StrokeThickness="1.3"
                                  StrokeLineCap="Round"
                                  VerticalAlignment="Center" />
                            <TextBox Grid.Column="1"
                                     Text="{Binding UrlInput, Mode=TwoWay}"
                                     PlaceholderText="Paste YouTube / yt-dlp URL…"
                                     VerticalContentAlignment="Center" />
                        </Grid>
                    </Border>
                    <!-- Inline blocked message + wizard link (shown when URL prereqs missing) -->
                    <StackPanel Orientation="Horizontal" Spacing="6"
                                IsVisible="{Binding ShowUrlBlockedMessage}">
                        <TextBlock Text="{Binding UrlInputBlockedMessage}"
                                   FontSize="11"
                                   Foreground="{DynamicResource ErrorBrush}"
                                   VerticalAlignment="Center"
                                   TextWrapping="Wrap" />
                        <Button Classes="fmtToggle"
                                Content="Re-run setup wizard"
                                Command="{Binding ShowWizardCommand}" />
                    </StackPanel>
                    <!-- URL validation error -->
                    <TextBlock Text="{Binding UrlInputError}"
                               IsVisible="{Binding HasUrlInputError}"
                               FontSize="11"
                               Foreground="{DynamicResource ErrorBrush}" />

                    <!-- Job options (URL-only) -->
                    <StackPanel Orientation="Horizontal" Spacing="12"
                                IsVisible="{Binding IsUrlInputEnabled}">
                        <CheckBox IsChecked="{Binding KeepSourceFile, Mode=TwoWay}"
                                  Content="Keep source file"
                                  FontSize="11"
                                  ToolTip.Tip="Save the downloaded source audio alongside the separation outputs." />
                    </StackPanel>

                    <!-- Format status row -->
                    <Panel IsVisible="{Binding ShowUrlFormatRow}">
                        <!-- Checking state: spinner arc + label -->
                        <StackPanel Orientation="Horizontal" Spacing="8"
                                    IsVisible="{Binding IsCheckingUrl}"
                                    VerticalAlignment="Center">
                            <Panel Width="14" Height="14" VerticalAlignment="Center">
                                <Ellipse Width="14" Height="14"
                                         Stroke="{DynamicResource Bg3Brush}"
                                         StrokeThickness="1.5"
                                         IsHitTestVisible="False" />
                                <Path Data="M 7,1 A 6,6 0 1 1 1,7"
                                      Stroke="{DynamicResource AccentBrush}"
                                      StrokeThickness="1.5"
                                      StrokeLineCap="Round"
                                      Stretch="None"
                                      RenderTransformOrigin="50%,50%">
                                    <Path.RenderTransform>
                                        <RotateTransform Angle="{Binding SpinnerAngle}" />
                                    </Path.RenderTransform>
                                </Path>
                            </Panel>
                            <TextBlock Text="Resolving format…"
                                       FontSize="11"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       VerticalAlignment="Center" />
                        </StackPanel>

                        <!-- Resolved state: styled chips -->
                        <StackPanel Orientation="Horizontal" Spacing="6"
                                    IsVisible="{Binding HasUrlTitle}"
                                    VerticalAlignment="Center">
                            <TextBlock Text="{Binding UrlTitle}"
                                       FontSize="11"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       TextTrimming="CharacterEllipsis"
                                       MaxWidth="200" />
                            <Border Classes="tag" IsVisible="{Binding HasUrlCodec}">
                                <TextBlock Text="{Binding UrlCodec}" />
                            </Border>
                            <Border Classes="tag" IsVisible="{Binding HasUrlBitrate}">
                                <TextBlock Text="{Binding UrlBitrate}" />
                            </Border>
                            <Border Classes="tag" IsVisible="{Binding HasUrlSampleRate}">
                                <TextBlock Text="{Binding UrlSampleRate}" />
                            </Border>
                            <Border Classes="tag" IsVisible="{Binding HasUrlDuration}">
                                <TextBlock Text="{Binding UrlDuration}" />
                            </Border>
                        </StackPanel>

                        <!-- Error state -->
                        <StackPanel Orientation="Horizontal" Spacing="8"
                                    IsVisible="{Binding HasUrlFetchError}"
                                    VerticalAlignment="Center">
                            <Path Data="M 7 1 L 13 12 L 1 12 Z M 7 5 L 7 8 M 7 10 L 7 10.5"
                                  Stroke="{DynamicResource ErrorBrush}"
                                  StrokeThickness="1.3"
                                  StrokeLineCap="Round"
                                  StrokeJoin="Round"
                                  Width="14" Height="14"
                                  Stretch="None"
                                  VerticalAlignment="Center" />
                            <TextBlock Text="{Binding UrlFetchError}"
                                       FontSize="11"
                                       Foreground="{DynamicResource ErrorBrush}"
                                       VerticalAlignment="Center" />
                            <Button Classes="ghost"
                                    Content="Retry"
                                    Command="{Binding RetryFetchCommand}"
                                    FontSize="11"
                                    Padding="4,1"
                                    VerticalAlignment="Center" />
                        </StackPanel>
                    </Panel>

                    <!-- Format picker toggle (separate line, accent link) -->
                    <Button Classes="fmtToggle"
                            x:Name="FormatPickerAnchor"
                            IsVisible="{Binding HasFormatPicker}"
                            Command="{Binding ToggleFormatPickerCommand}"
                            Content="{Binding FormatPickerToggleLabel}" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- ===== Format picker overlay — in-window, sits above content row.
        RowSpan=4 + Top/Left alignment makes the layout slot the entire grid so the
        code-behind can position it precisely under FormatPickerAnchor via Margin. ===== -->
        <Border Grid.Row="0" Grid.RowSpan="4"
                x:Name="FormatPickerOverlay"
                IsVisible="{Binding IsFormatPickerOpen}"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Width="470"
                ZIndex="10"
                Background="{DynamicResource Bg2Brush}"
                BorderBrush="{DynamicResource Bg3Brush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="6,6"
                BoxShadow="0 8 32 0 #C8000000, 0 0 0 1 #22FFFFFF">
            <StackPanel>
                <!-- Column headers -->
                <Grid ColumnDefinitions="40,56,68,60,*,82,40" ColumnSpacing="8"
                      Margin="6,0,6,4">
                    <TextBlock Grid.Column="0" Text="ID"
                               Classes="sectionLabel"
                               FontSize="9" LetterSpacing="1" />
                    <TextBlock Grid.Column="1" Text="CODEC"
                               Classes="sectionLabel"
                               FontSize="9" LetterSpacing="1" />
                    <TextBlock Grid.Column="2" Text="BITRATE"
                               Classes="sectionLabel"
                               FontSize="9" LetterSpacing="1" />
                    <TextBlock Grid.Column="3" Text="SR"
                               Classes="sectionLabel"
                               FontSize="9" LetterSpacing="1" />
                    <TextBlock Grid.Column="4" Text="NOTE"
                               Classes="sectionLabel"
                               FontSize="9" LetterSpacing="1" />
                </Grid>

                <!-- Format rows -->
                <ItemsControl ItemsSource="{Binding FormatPickerItems}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="vm:FormatPickerItem">
                            <Border Classes="fmtRow"
                                    Classes.selected="{Binding IsSelected}"
                                    PointerPressed="OnFormatRowClicked">
                                <Grid ColumnDefinitions="40,56,68,60,*,82,40" ColumnSpacing="8">
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding FormatId}"
                                               Classes="mono"
                                               FontSize="11"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis" />
                                    <Border Grid.Column="1" Classes="tag" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Codec}"
                                                   TextTrimming="CharacterEllipsis"
                                                   MaxWidth="56" />
                                    </Border>
                                    <TextBlock Grid.Column="2"
                                               Text="{Binding Bitrate}"
                                               Classes="mono"
                                               FontSize="11"
                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                               VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="3"
                                               Text="{Binding SampleRate}"
                                               Classes="mono"
                                               FontSize="11"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="4"
                                               Text="{Binding FormatNote}"
                                               FontSize="10"
                                               Foreground="{DynamicResource TextPlaceholderBrush}"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis" />
                                    <!-- YouTube Premium logo (SVG paths from Wikimedia Commons,
                                    viewBox 846x174). Scaled into the row via Viewbox. -->
                                    <Viewbox Grid.Column="5"
                                             IsVisible="{Binding IsYtPremium}"
                                             Width="58" Height="12"
                                             Stretch="Uniform"
                                             HorizontalAlignment="Left"
                                             VerticalAlignment="Center"
                                             ToolTip.Tip="YouTube Premium-only format">
                                        <Canvas Width="846" Height="174">
                                            <Path Fill="#FF0000"
                                                  Data="M 242.88,27.11 A 31.07,31.07 0 0 0 220.95,5.18 C 201.6,0 124,0 124,0 124,0 46.46,0 27.11,5.18 A 31.07,31.07 0 0 0 5.18,27.11 C 0,46.46 0,86.82 0,86.82 c 0,0 0,40.36 5.18,59.71 a 31.07,31.07 0 0 0 21.93,21.93 c 19.35,5.18 96.92,5.18 96.92,5.18 0,0 77.57,0 96.92,-5.18 a 31.07,31.07 0 0 0 21.93,-21.93 c 5.18,-19.35 5.18,-59.71 5.18,-59.71 0,0 0,-40.36 -5.18,-59.71 z" />
                                            <Path Fill="White"
                                                  Data="M 99.22,124.03 L 163.67,86.82 L 99.22,49.61 Z" />
                                            <Path Fill="{DynamicResource TextPrimaryBrush}"
                                                  Data="M 358.29,55.1 v 6 c 0,30 -13.3,47.53 -42.39,47.53 h -4.43 v 52.5 H 287.71 V 12.36 H 318 c 27.7,0 40.29,11.71 40.29,42.74 z m -25,2.13 c 0,-21.64 -3.9,-26.78 -17.38,-26.78 h -4.43 v 60.48 h 4.08 c 12.77,0 17.74,-9.22 17.74,-29.26 z m 81.22,-6.56 -1.24,28.2 c -10.11,-2.13 -18.45,-0.53 -22.17,6 v 76.26 H 367.52 V 52.44 h 18.8 L 388.45,76 h 0.89 c 2.48,-17.2 10.46,-25.89 20.75,-25.89 a 22.84,22.84 0 0 1 4.42,0.56 z M 441.64,115 v 5.5 c 0,19.16 1.06,25.72 9.22,25.72 7.8,0 9.58,-6 9.75,-18.44 l 21.1,1.24 c 1.6,23.41 -10.64,33.87 -31.39,33.87 -25.18,0 -32.63,-16.49 -32.63,-46.46 v -19 c 0,-31.57 8.34,-47 33.34,-47 25.18,0 31.57,13.12 31.57,45.93 V 115 Z m 0,-22.35 v 7.8 h 17.91 V 92.7 c 0,-20 -1.42,-25.72 -9,-25.72 -7.58,0 -8.91,5.86 -8.91,25.72 z M 604.45,79 v 82.11 H 580 V 80.82 c 0,-8.87 -2.31,-13.3 -7.63,-13.3 -4.26,0 -8.16,2.48 -10.82,7.09 a 35.59,35.59 0 0 1 0.18,4.43 v 82.11 H 537.24 V 80.82 c 0,-8.87 -2.31,-13.3 -7.63,-13.3 -4.26,0 -8,2.48 -10.64,6.92 v 86.72 H 494.5 V 52.44 h 19.33 L 516,66.28 h 0.35 c 5.5,-10.46 14.37,-16.14 24.83,-16.14 10.29,0 16.14,5.14 18.8,14.37 5.68,-9.4 14.19,-14.37 23.94,-14.37 14.86,0 20.53,10.64 20.53,28.86 z m 12.24,-54.4 c 0,-11.71 4.26,-15.07 13.3,-15.07 9.22,0 13.3,3.9 13.3,15.07 0,12.06 -4.08,15.08 -13.3,15.08 -9.04,-0.01 -13.3,-3.02 -13.3,-15.08 z m 1.42,27.84 h 23.41 v 108.72 h -23.41 z m 103.39,0 v 108.72 h -19.15 l -2.13,-13.3 h -0.53 c -5.5,10.64 -13.48,15.07 -23.41,15.07 -14.54,0 -21.11,-9.22 -21.11,-29.26 V 52.44 h 24.47 v 79.81 c 0,9.58 2,13.48 6.92,13.48 A 12.09,12.09 0 0 0 697,138.81 V 52.44 Z M 845.64,79 v 82.11 H 821.17 V 80.82 c 0,-8.87 -2.31,-13.3 -7.63,-13.3 -4.26,0 -8.16,2.48 -10.82,7.09 A 35.59,35.59 0 0 1 802.9,79 v 82.11 H 778.43 V 80.82 c 0,-8.87 -2.31,-13.3 -7.63,-13.3 -4.26,0 -8,2.48 -10.64,6.92 v 86.72 H 735.69 V 52.44 H 755 l 2.13,13.83 h 0.35 c 5.5,-10.46 14.37,-16.14 24.83,-16.14 10.29,0 16.14,5.14 18.8,14.37 5.68,-9.4 14.19,-14.37 23.94,-14.37 14.95,0.01 20.59,10.65 20.59,28.87 z" />
                                        </Canvas>
                                    </Viewbox>
                                    <Border Grid.Column="6"
                                            IsVisible="{Binding IsAutoRecommended}"
                                            Background="{DynamicResource AccentDimBgBrush}"
                                            CornerRadius="3"
                                            Padding="5,2"
                                            VerticalAlignment="Center">
                                        <TextBlock Text="Auto"
                                                   FontSize="9"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource AccentBrush}" />
                                    </Border>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>

        <!-- ===== Content: preset grid or models table ===== -->
        <ScrollViewer Grid.Row="2" HorizontalScrollBarVisibility="Disabled">
            <Grid Margin="20,16,20,16">
                <!-- Built-in presets -->
                <ItemsControl ItemsSource="{Binding Categories}"
                              IsVisible="{Binding IsBuiltInMode}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Vertical" Spacing="14" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="vm:PresetCategoryGroup">
                            <StackPanel Spacing="8">
                                <!-- Category header -->
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Border Width="3" Height="14"
                                            Background="{Binding AccentBrush}"
                                            CornerRadius="2" />
                                    <TextBlock Classes="sectionLabel"
                                               Text="{Binding Label}"
                                               VerticalAlignment="Center" />
                                </StackPanel>

                                <!-- 2-column preset grid -->
                                <ItemsControl ItemsSource="{Binding Items}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <UniformGrid Columns="2" Margin="0,0,-7,0" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="vm:PresetItemViewModel">
                                            <Border Classes="preset"
                                                    Classes.selected="{Binding IsSelected}"
                                                    Margin="0,0,7,7"
                                                    PointerPressed="OnPresetCardClicked">
                                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                                                    <!-- Checkbox -->
                                                    <Border Grid.Column="0" Classes="checkbox">
                                                        <Path Data="M1 4 L4 7 L9 1"
                                                              Stroke="White" StrokeThickness="1.5"
                                                              StrokeLineCap="Round" StrokeJoin="Round"
                                                              Stretch="None"
                                                              Width="10" Height="8"
                                                              HorizontalAlignment="Center" VerticalAlignment="Center"
                                                              IsVisible="{Binding IsSelected}" />
                                                    </Border>

                                                    <!-- Body -->
                                                    <StackPanel Grid.Column="1" Spacing="2">
                                                        <TextBlock Classes="presetName" Text="{Binding Label}" />
                                                        <TextBlock Text="{Binding Description}"
                                                                   FontSize="11"
                                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                                   TextWrapping="Wrap" />
                                                        <StackPanel Orientation="Horizontal" Spacing="5" Margin="0,4,0,0">
                                                            <Border Classes="tag">
                                                                <ToolTip.Tip>
                                                                    <StackPanel Spacing="4"
                                                                                IsVisible="{Binding HasModelsList}">
                                                                        <TextBlock Text="MODELS"
                                                                                   FontSize="9"
                                                                                   FontWeight="SemiBold"
                                                                                   Foreground="{DynamicResource AccentBrush}"
                                                                                   Margin="0,0,0,4"
                                                                                   LetterSpacing="1" />
                                                                        <ItemsControl ItemsSource="{Binding ModelsList}">
                                                                            <ItemsControl.ItemTemplate>
                                                                                <DataTemplate>
                                                                                    <TextBlock Text="{Binding}"
                                                                                               FontSize="11"
                                                                                               FontFamily="{DynamicResource MonoFont}"
                                                                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                                                                               TextWrapping="NoWrap" />
                                                                                </DataTemplate>
                                                                            </ItemsControl.ItemTemplate>
                                                                        </ItemsControl>
                                                                    </StackPanel>
                                                                </ToolTip.Tip>
                                                                <TextBlock Text="{Binding ModelsTag}" />
                                                            </Border>
                                                            <Border Classes="tag"
                                                                    IsVisible="{Binding HasAlgorithmTag}"
                                                                    ToolTip.Tip="{Binding AlgorithmTooltip}">
                                                                <TextBlock Text="{Binding AlgorithmTag}" />
                                                            </Border>
                                                        </StackPanel>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- My Presets panel -->
                <Panel IsVisible="{Binding IsMyPresetsMode}">

                    <!-- Empty state -->
                    <StackPanel IsVisible="{Binding !HasUserPresets}"
                                HorizontalAlignment="Center" VerticalAlignment="Top"
                                Margin="0,48" Spacing="8">
                        <TextBlock Text="No custom presets yet."
                                   FontSize="13" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center" />
                        <TextBlock Text="Go to the Models tab to browse models and save a custom preset."
                                   FontSize="12"
                                   Foreground="{DynamicResource TextPlaceholderBrush}"
                                   HorizontalAlignment="Center" />
                    </StackPanel>

                    <!-- User preset grid (same card style as built-in).
                    Wrapped in a StackPanel so the inner UniformGrid measures to its natural
                    row-height; without it, a single row stretches vertically to fill the
                    entire ScrollViewer viewport. Built-in presets get the same constraint
                    implicitly because each category lives inside its own category StackPanel. -->
                    <StackPanel IsVisible="{Binding HasUserPresets}">
                        <ItemsControl ItemsSource="{Binding UserPresetItems}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="2" Margin="0,0,-7,0" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="vm:PresetItemViewModel">
                                    <!-- Panel so the × overlays without disrupting the card layout -->
                                    <Panel Margin="0,0,7,7">
                                        <Border Classes="preset"
                                                Classes.selected="{Binding IsSelected}"
                                                PointerPressed="OnPresetCardClicked">
                                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                                                <!-- Checkbox -->
                                                <Border Grid.Column="0" Classes="checkbox">
                                                    <Path Data="M1 4 L4 7 L9 1"
                                                          Stroke="White" StrokeThickness="1.5"
                                                          StrokeLineCap="Round" StrokeJoin="Round"
                                                          Stretch="None"
                                                          Width="10" Height="8"
                                                          HorizontalAlignment="Center" VerticalAlignment="Center"
                                                          IsVisible="{Binding IsSelected}" />
                                                </Border>

                                                <!-- Body -->
                                                <StackPanel Grid.Column="1" Spacing="2" Margin="0,0,22,0">
                                                    <TextBlock Classes="presetName" Text="{Binding Label}" />
                                                    <TextBlock Text="{Binding Description}"
                                                               FontSize="11"
                                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                                               TextWrapping="NoWrap"
                                                               TextTrimming="CharacterEllipsis" />
                                                    <StackPanel Orientation="Horizontal" Spacing="5" Margin="0,4,0,0">
                                                        <Border Classes="tag">
                                                            <ToolTip.Tip>
                                                                <StackPanel Spacing="4"
                                                                            IsVisible="{Binding HasModelsList}">
                                                                    <TextBlock Text="MODELS"
                                                                               FontSize="9"
                                                                               FontWeight="SemiBold"
                                                                               Foreground="{DynamicResource AccentBrush}"
                                                                               Margin="0,0,0,4"
                                                                               LetterSpacing="1" />
                                                                    <ItemsControl ItemsSource="{Binding ModelsList}">
                                                                        <ItemsControl.ItemTemplate>
                                                                            <DataTemplate>
                                                                                <TextBlock Text="{Binding}"
                                                                                           FontSize="11"
                                                                                           FontFamily="{DynamicResource MonoFont}"
                                                                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                                                                           TextWrapping="NoWrap" />
                                                                            </DataTemplate>
                                                                        </ItemsControl.ItemTemplate>
                                                                    </ItemsControl>
                                                                </StackPanel>
                                                            </ToolTip.Tip>
                                                            <TextBlock Text="{Binding ModelsTag}" />
                                                        </Border>
                                                        <Border Classes="tag"
                                                                IsVisible="{Binding HasAlgorithmTag}"
                                                                ToolTip.Tip="{Binding AlgorithmTooltip}">
                                                            <TextBlock Text="{Binding AlgorithmTag}" />
                                                        </Border>
                                                    </StackPanel>
                                                </StackPanel>
                                            </Grid>
                                        </Border>

                                        <!-- × overlaid top-right, doesn't affect card layout -->
                                        <Button HorizontalAlignment="Right"
                                                VerticalAlignment="Top"
                                                Classes="ghost"
                                                Content="×"
                                                FontSize="14"
                                                Padding="5,2"
                                                Margin="0,4,4,0"
                                                Command="{Binding $parent[ItemsControl].((vm:SeparateViewModel)DataContext).RemoveUserPresetCommand}"
                                                CommandParameter="{Binding}" />
                                    </Panel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                </Panel>
            </Grid>
        </ScrollViewer>

        <!-- ===== Footer ===== -->
        <Border Grid.Row="3"
                Background="{DynamicResource Bg0Brush}"
                BorderBrush="{DynamicResource Bg3Brush}"
                BorderThickness="0,1,0,0"
                Padding="20,0">
            <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto,Auto,Auto,Auto" ColumnSpacing="12">
                <Path Grid.Column="0"
                      Data="M2 11 V3 A1 1 0 0 1 3 2 H11 A1 1 0 0 1 12 3 V11 M5 13 H9"
                      Width="14" Height="14" Stretch="None"
                      Stroke="{DynamicResource TextSecondaryBrush}" StrokeThickness="1.3"
                      StrokeLineCap="Round"
                      VerticalAlignment="Center" />
                <TextBlock Grid.Column="1" Classes="mono"
                           Text="{Binding OutputPath}"
                           FontSize="12"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           TextTrimming="CharacterEllipsis"
                           ToolTip.Tip="{Binding OutputPath}"
                           VerticalAlignment="Center" />
                <Button Grid.Column="2" Classes="ghost"
                        Content="Browse"
                        Click="OnBrowseOutputClicked" />
                <Border Grid.Column="3" Width="1" Height="24"
                        Background="{DynamicResource Bg3Brush}"
                        VerticalAlignment="Center" />
                <!-- Output configuration: stem format + extra drum stem option -->
                <StackPanel Grid.Column="4" Orientation="Horizontal" Spacing="14" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                        <TextBlock Text="Stems:"
                                   FontSize="11"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   VerticalAlignment="Center" />
                        <ComboBox ItemsSource="{Binding AudioFormatOptions}"
                                  SelectedItem="{Binding StemOutputFormat, Mode=TwoWay}"
                                  MinWidth="80" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                        <CheckBox IsChecked="{Binding ExtractDrums, Mode=TwoWay}"
                                  Content="Add drum stem to output"
                                  FontSize="11" />
                        <Border Classes="infoIcon"
                                ToolTip.Tip="Saves a separate drum-only file alongside your selected stems. Useful as a transient reference when warping audio in DAWs — drum hits give clearer warp-marker hints than vocal or instrumental clips alone.">
                            <TextBlock Text="i"
                                       FontSize="9"
                                       FontStyle="Italic"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextSecondaryBrush}" />
                        </Border>
                    </StackPanel>
                </StackPanel>
                <Border Grid.Column="5" Width="1" Height="24"
                        Background="{DynamicResource Bg3Brush}"
                        VerticalAlignment="Center" />
                <!-- Preset count -->
                <StackPanel Grid.Column="6" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="{Binding SelectedCount}"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource AccentBrush}"
                               IsVisible="{Binding HasSelection}" />
                    <TextBlock Text="{Binding SelectedCountLabel}"
                               FontSize="12"
                               Foreground="{DynamicResource TextSecondaryBrush}" />
                </StackPanel>
                <!-- Action buttons -->
                <StackPanel Grid.Column="7" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                    <Button Classes="ghost"
                            Content="Add to Queue"
                            Command="{Binding AddToQueueCommand}" />
                    <Button Classes="accent"
                            Content="▶  Run"
                            Command="{Binding RunCommand}" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
