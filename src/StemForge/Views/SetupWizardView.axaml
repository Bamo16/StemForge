<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:StemForge.ViewModels"
             xmlns:ext="using:StemForge.Extensions"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="1100" d:DesignHeight="720"
             x:Class="StemForge.Views.SetupWizardView"
             x:DataType="vm:SetupWizardViewModel">

    <UserControl.Styles>
        <Style Selector="Button.variantTab">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Bg3Brush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="14,7" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="Medium" />
        </Style>
        <Style Selector="Button.variantTab.active">
            <Setter Property="Background" Value="{DynamicResource AccentDimBgBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
        </Style>
        <Style Selector="Button.variantTab:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource Bg2Brush}" />
        </Style>

        <Style Selector="Ellipse.stepDot">
            <Setter Property="Width" Value="8" />
            <Setter Property="Height" Value="8" />
            <Setter Property="Fill" Value="{DynamicResource Bg3Brush}" />
        </Style>
        <Style Selector="Ellipse.stepDot.active">
            <Setter Property="Fill" Value="{DynamicResource AccentBrush}" />
        </Style>

        <Style Selector="TextBox.dirInput">
            <Setter Property="Background" Value="{DynamicResource Bg0Brush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Bg3Brush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="FontFamily" Value="{DynamicResource MonoFont}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        </Style>

        <Style Selector="Ellipse.statusDot">
            <Setter Property="Width" Value="7" />
            <Setter Property="Height" Value="7" />
        </Style>
        <Style Selector="Ellipse.statusDot.ok">
            <Setter Property="Fill" Value="{DynamicResource SuccessBrush}" />
        </Style>
        <Style Selector="Ellipse.statusDot.fail">
            <Setter Property="Fill" Value="{DynamicResource ErrorBrush}" />
        </Style>

        <!-- Install-row text styling -->
        <Style Selector="TextBlock.toolName">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style Selector="TextBlock.toolName.satisfied">
            <Setter Property="Foreground" Value="{DynamicResource TextPlaceholderBrush}" />
        </Style>
        <Style Selector="TextBlock.requiredTag">
            <Setter Property="FontSize" Value="9" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="LetterSpacing" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Text" Value="REQUIRED" />
        </Style>
        <Style Selector="TextBlock.optionalTag">
            <Setter Property="FontSize" Value="9" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="LetterSpacing" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource TextPlaceholderBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Text" Value="OPTIONAL" />
        </Style>
        <Style Selector="TextBlock.toolDesc">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="{DynamicResource TextPlaceholderBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="MaxWidth" Value="320" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style Selector="TextBlock.toolSize">
            <Setter Property="FontSize" Value="10" />
            <Setter Property="Foreground" Value="{DynamicResource TextPlaceholderBrush}" />
            <Setter Property="Opacity" Value="0.75" />
            <Setter Property="FontStyle" Value="Italic" />
        </Style>
        <Style Selector="TextBlock.installOutcome">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
    </UserControl.Styles>

    <!-- Full-screen dim overlay -->
    <Panel>
        <Border>
            <Border.Background>
                <SolidColorBrush Color="Black" Opacity="0.6" />
            </Border.Background>
        </Border>

        <!-- Centered wizard card -->
        <Border MaxWidth="480"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="{DynamicResource Bg1Brush}"
                BorderBrush="{DynamicResource Bg3Brush}"
                BorderThickness="1"
                CornerRadius="14"
                BoxShadow="0 8 40 0 #60000000">

            <StackPanel>

                <!-- Step indicator dots (hidden on Welcome) -->
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Spacing="8"
                            Margin="0,24,0,0"
                            IsVisible="{Binding !IsWelcomeStep}">
                    <Ellipse Classes="stepDot" Classes.active="{Binding IsStep1Active}" />
                    <Ellipse Classes="stepDot" Classes.active="{Binding IsStep2Active}" />
                    <Ellipse Classes="stepDot" Classes.active="{Binding IsStep3Active}" />
                    <Ellipse Classes="stepDot" Classes.active="{Binding IsStep4Active}" />
                </StackPanel>

                <!-- Step content -->
                <Panel MinHeight="340" Margin="32,24,32,0">

                    <!-- ── Welcome ── -->
                    <StackPanel IsVisible="{Binding IsWelcomeStep}"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Center"
                                Spacing="16">
                        <TextBlock Text="StemForge"
                                   FontSize="32" FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   Foreground="{DynamicResource TextPrimaryBrush}" />
                        <TextBlock Text="AI-powered audio stem separation"
                                   FontSize="14"
                                   HorizontalAlignment="Center"
                                   Foreground="{DynamicResource TextSecondaryBrush}" />
                        <TextBlock MaxWidth="340"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"
                                   FontSize="13"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   Margin="0,8,0,0"
                                   Text="This wizard will check your system, configure directories, and install audio-separator if needed." />
                    </StackPanel>

                    <!-- ── Detect ── -->
                    <StackPanel IsVisible="{Binding IsDetectStep}" Spacing="16">
                        <TextBlock Text="Checking your system"
                                   FontSize="18" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}" />

                        <StackPanel IsVisible="{Binding IsDetecting}" Spacing="10">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Ellipse Width="7" Height="7">
                                    <Ellipse.Fill>
                                        <SolidColorBrush Color="{DynamicResource SuccessColor}" Opacity="0.5" />
                                    </Ellipse.Fill>
                                </Ellipse>
                                <TextBlock Text="Detecting tools…"
                                           FontSize="12" FontWeight="Bold"
                                           Foreground="{DynamicResource TextSecondaryBrush}" />
                            </StackPanel>
                            <ProgressBar IsIndeterminate="True" Height="2"
                                         Foreground="{DynamicResource SuccessBrush}"
                                         Background="Transparent" />
                        </StackPanel>

                        <StackPanel IsVisible="{Binding !IsDetecting}" Spacing="10">
                            <ItemsControl ItemsSource="{Binding Tools}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Spacing="6" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="vm:ToolStatusViewModel">
                                        <!-- Single line: dot, name, version, variant chip — matches
                                             the Settings status header so the two reads consistently. -->
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <Ellipse Classes="statusDot"
                                                     Classes.ok="{Binding Found}"
                                                     Classes.fail="{Binding !Found}"
                                                     VerticalAlignment="Center" />
                                            <TextBlock Text="{Binding Name}"
                                                       FontSize="11" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                                       VerticalAlignment="Center" />
                                            <TextBlock Classes="mono"
                                                       Text="{Binding StatusLine}"
                                                       FontSize="11"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       VerticalAlignment="Center" />
                                            <Border IsVisible="{Binding VariantTag, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                                    Background="{DynamicResource AccentDimBgBrush}"
                                                    CornerRadius="3" Padding="4,1"
                                                    VerticalAlignment="Center">
                                                <TextBlock Text="{Binding VariantTag}"
                                                           FontSize="9" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource AccentBrush}" />
                                            </Border>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <TextBlock FontSize="11" FontWeight="Medium"
                                       Foreground="{DynamicResource AccentBrush}"
                                       Margin="0,4,0,0"
                                       Text="{Binding GpuHint}"
                                       IsVisible="{Binding GpuHint, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                        </StackPanel>
                    </StackPanel>

                    <!-- ── Directories ── -->
                    <StackPanel IsVisible="{Binding IsDirectoriesStep}" Spacing="16">
                        <TextBlock Text="Output directories"
                                   FontSize="18" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}" />
                        <TextBlock FontSize="13"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   TextWrapping="Wrap"
                                   Text="Where should StemForge save separated stems and store AI models?" />

                        <StackPanel Spacing="6">
                            <TextBlock FontSize="12"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       Text="Stems output" />
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                <TextBox Grid.Column="0" Classes="dirInput"
                                         Text="{Binding OutputDirectory, Mode=TwoWay}" />
                                <Button Grid.Column="1" Classes="ghost"
                                        Content="Browse"
                                        Click="OnBrowseOutputClicked" />
                            </Grid>
                        </StackPanel>

                        <StackPanel Spacing="6">
                            <TextBlock FontSize="12"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       Text="Models cache" />
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                <TextBox Grid.Column="0" Classes="dirInput"
                                         Text="{Binding ModelsDirectory, Mode=TwoWay}" />
                                <Button Grid.Column="1" Classes="ghost"
                                        Content="Browse"
                                        Click="OnBrowseModelsClicked" />
                            </Grid>
                        </StackPanel>
                    </StackPanel>

                    <!-- ── Install ── -->
                    <StackPanel IsVisible="{Binding IsInstallStep}" Spacing="16">
                        <TextBlock Text="Install tools"
                                   FontSize="18" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}" />
                        <TextBlock FontSize="12" TextWrapping="Wrap"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   Text="Choose what to install. Already-installed tools are checked off — uncheck anything you'd like to skip." />

                        <!-- One row per tool (catalog order: required first, then optional) -->
                        <ItemsControl ItemsSource="{Binding InstallRows}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Spacing="12" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="vm:ToolRowViewModel">
                                    <StackPanel Spacing="6">
                                        <!-- Header row: indicator, name, REQUIRED/OPTIONAL, then either
                                             the installed-outcome (when Found) or a 2-line sub-stack
                                             with description + size estimate to the right (when not). -->
                                        <StackPanel Orientation="Horizontal" Spacing="10">
                                            <Panel Width="22" VerticalAlignment="Center">
                                                <CheckBox IsChecked="{Binding WantInstall, Mode=TwoWay}"
                                                          IsVisible="{Binding !Found}"
                                                          HorizontalAlignment="Center" VerticalAlignment="Center"
                                                          MinWidth="0" Padding="0" Margin="0" />
                                                <Path Data="M0 6 L4 10 L12 1"
                                                      Stroke="{DynamicResource SuccessBrush}" StrokeThickness="2"
                                                      StrokeLineCap="Round" StrokeJoin="Round"
                                                      Stretch="None" Width="14" Height="14"
                                                      HorizontalAlignment="Center" VerticalAlignment="Center"
                                                      IsVisible="{Binding Found}" />
                                            </Panel>
                                            <TextBlock Classes="toolName"
                                                       Classes.satisfied="{Binding Found}"
                                                       Text="{Binding Name}" />
                                            <TextBlock Classes="requiredTag"
                                                       IsVisible="{Binding IsRequired}" />
                                            <TextBlock Classes="optionalTag"
                                                       IsVisible="{Binding !IsRequired}" />
                                            <TextBlock Classes="installOutcome"
                                                       Foreground="{DynamicResource SuccessBrush}"
                                                       Text="✓ installed"
                                                       IsVisible="{Binding ShowInstalledNow}" />
                                            <TextBlock Classes="installOutcome"
                                                       Foreground="{DynamicResource TextPlaceholderBrush}"
                                                       Text="✓ already installed"
                                                       IsVisible="{Binding ShowAlreadyInstalled}" />
                                            <!-- Description + size sub-stack, inline to the right -->
                                            <StackPanel Spacing="2" VerticalAlignment="Center">
                                                <TextBlock Classes="toolDesc"
                                                           Text="{Binding Description}"
                                                           IsVisible="{Binding !Found}" />
                                                <TextBlock Classes="toolSize"
                                                           Text="{Binding DownloadSize}">
                                                    <TextBlock.IsVisible>
                                                        <MultiBinding Converter="{x:Static BoolConverters.And}">
                                                            <Binding Path="!Found" />
                                                            <Binding Path="HasDownloadSize" />
                                                        </MultiBinding>
                                                    </TextBlock.IsVisible>
                                                </TextBlock>
                                            </StackPanel>
                                        </StackPanel>

                                        <!-- Inline variant picker (audio-separator only, when queued) -->
                                        <StackPanel Spacing="8" Margin="28,0,0,0"
                                                    IsVisible="{Binding ShowVariantPicker}">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <Button Classes="variantTab"
                                                        IsVisible="{Binding VariantPicker.HasCpuVariant}"
                                                        Classes.active="{Binding VariantPicker.IsCpu}"
                                                        Command="{Binding VariantPicker.SetVariantCommand}"
                                                        CommandParameter="Cpu" Content="CPU" />
                                                <Button Classes="variantTab"
                                                        IsVisible="{Binding VariantPicker.HasCudaVariant}"
                                                        Classes.active="{Binding VariantPicker.IsCuda}"
                                                        Command="{Binding VariantPicker.SetVariantCommand}"
                                                        CommandParameter="Cuda" Content="CUDA" />
                                                <Button Classes="variantTab"
                                                        IsVisible="{Binding VariantPicker.HasDirectMLVariant}"
                                                        Classes.active="{Binding VariantPicker.IsDirectML}"
                                                        Command="{Binding VariantPicker.SetVariantCommand}"
                                                        CommandParameter="DirectML" Content="DirectML" />
                                            </StackPanel>
                                            <TextBlock FontSize="11"
                                                       Foreground="{DynamicResource TextPlaceholderBrush}"
                                                       TextWrapping="Wrap"
                                                       Text="CPU works everywhere. CUDA requires NVIDIA." />
                                            <TextBlock FontSize="11"
                                                       IsVisible="{Binding VariantPicker.HasDirectMLVariant}"
                                                       Foreground="{DynamicResource TextPlaceholderBrush}"
                                                       TextWrapping="Wrap"
                                                       Text="DirectML works on most Windows GPUs." />
                                            <TextBlock FontSize="11" FontWeight="Medium"
                                                       Foreground="{DynamicResource AccentBrush}"
                                                       TextWrapping="Wrap"
                                                       Text="{Binding VariantPicker.GpuHint}"
                                                       IsVisible="{Binding VariantPicker.GpuHint, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                                        </StackPanel>

                                        <!-- Per-row install error -->
                                        <TextBlock Margin="28,0,0,0" FontSize="11" TextWrapping="Wrap"
                                                   Foreground="{DynamicResource ErrorBrush}"
                                                   Text="{Binding InstallError}"
                                                   IsVisible="{Binding InstallError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Install button — hides entirely when nothing's selected for install -->
                        <Button Classes="accent"
                                Content="Install selected"
                                Command="{Binding InstallSelectedCommand}"
                                IsEnabled="{Binding !IsInstalling}"
                                IsVisible="{Binding HasAnythingToInstall}"
                                HorizontalAlignment="Left" />

                        <!-- Shared install log -->
                        <ScrollViewer MaxHeight="120"
                                      HorizontalScrollBarVisibility="Disabled"
                                      ext:ScrollViewerExtensions.AutoScrollToEnd="True"
                                      IsVisible="{Binding InstallLog, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                            <TextBlock Classes="mono"
                                       Text="{Binding InstallLog}"
                                       FontSize="11"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       TextWrapping="Wrap" />
                        </ScrollViewer>
                    </StackPanel>

                    <!-- ── Finish ── -->
                    <StackPanel IsVisible="{Binding IsFinishStep}"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Center"
                                Spacing="16">
                        <Border Width="56" Height="56"
                                CornerRadius="28"
                                HorizontalAlignment="Center">
                            <Border.Background>
                                <SolidColorBrush Color="{DynamicResource SuccessColor}" Opacity="0.15" />
                            </Border.Background>
                            <TextBlock Text="✓"
                                       FontSize="26" FontWeight="Bold"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource SuccessBrush}" />
                        </Border>
                        <TextBlock Text="You're all set!"
                                   FontSize="22" FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   Foreground="{DynamicResource TextPrimaryBrush}" />
                        <TextBlock MaxWidth="320"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"
                                   FontSize="13"
                                   HorizontalAlignment="Center"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   Text="StemForge is ready. You can change these settings anytime from the Settings screen." />
                    </StackPanel>

                </Panel>

                <!-- Nav buttons -->
                <Grid ColumnDefinitions="Auto,*,Auto"
                      Margin="32,20,32,28">

                    <!-- Back (middle steps) or Close (welcome re-run) -->
                    <Button Grid.Column="0"
                            Classes="ghost"
                            Content="Back"
                            Command="{Binding BackCommand}"
                            IsVisible="{Binding IsBackVisible}" />
                    <Button Grid.Column="0"
                            Classes="ghost"
                            Content="Close"
                            Command="{Binding DismissCommand}">
                        <Button.IsVisible>
                            <MultiBinding Converter="{x:Static BoolConverters.And}">
                                <Binding Path="IsWelcomeStep" />
                                <Binding Path="CanDismiss" />
                            </MultiBinding>
                        </Button.IsVisible>
                    </Button>

                    <!-- Welcome: Get Started -->
                    <Button Grid.Column="2"
                            Classes="accent"
                            Content="Get Started"
                            Command="{Binding StartCommand}"
                            IsVisible="{Binding IsWelcomeStep}" />

                    <!-- Detect / Directories / Install: Next -->
                    <Button Grid.Column="2"
                            Classes="accent"
                            Content="Next"
                            Command="{Binding NextCommand}"
                            IsEnabled="{Binding CanGoNext}">
                        <Button.IsVisible>
                            <MultiBinding Converter="{x:Static BoolConverters.And}">
                                <Binding Path="!IsWelcomeStep" />
                                <Binding Path="!IsFinishStep" />
                            </MultiBinding>
                        </Button.IsVisible>
                    </Button>

                    <!-- Finish: Start using StemForge -->
                    <Button Grid.Column="2"
                            Classes="accent"
                            Content="Start using StemForge"
                            Command="{Binding FinishCommand}"
                            IsVisible="{Binding IsFinishStep}" />

                </Grid>

            </StackPanel>
        </Border>
    </Panel>

</UserControl>
