<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Design-time style gallery: a representative sample of the app's controls and tokens, so
    theme/font changes (Tokens.axaml) can be previewed live in the IDE panel without running
    the app. Design-time only (stripped at runtime). Tokens are merged here so the brushes
    and fonts resolve; the Window style above supplies the UI font + foreground. -->
    <Design.PreviewWith>
        <Border Padding="24" Background="{DynamicResource Bg0Brush}">
            <Border.Resources>
                <ResourceDictionary>
                    <ResourceDictionary.MergedDictionaries>
                        <ResourceInclude Source="avares://StemForge/Styles/Tokens.axaml" />
                    </ResourceDictionary.MergedDictionaries>
                </ResourceDictionary>
            </Border.Resources>
            <Border Width="420"
                    Background="{DynamicResource Bg1Brush}"
                    CornerRadius="8"
                    Padding="24">
                <StackPanel Spacing="16">

                    <!-- Typography -->
                    <TextBlock Classes="h1" Text="Heading" />
                    <TextBlock Classes="sectionLabel" Text="SECTION LABEL" />
                    <TextBlock Text="Body text in the UI font." />
                    <TextBlock Classes="secondary" Text="Secondary text." />
                    <TextBlock Classes="mono" Text="Mono v0.2.0  0123456789" />

                    <!-- Buttons + info affordance -->
                    <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                        <Button Classes="accent" Content="Primary" />
                        <Button Classes="ghost" Content="Secondary" />
                        <Border Classes="infoIcon" ToolTip.Tip="Tooltip affordance">
                            <TextBlock Text="i"
                                       FontSize="10"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextSecondaryBrush}" />
                        </Border>
                    </StackPanel>

                    <!-- Progress. Foreground is pinned to the accent so the preview matches the
                    app: there, native Fluent controls are tinted amber via the SystemAccentColor
                    override in Tokens.axaml (ADR 0004), which the IDE previewer doesn't apply,
                    so the previewer's Fluent accent would otherwise show its default blue. -->
                    <!-- Animated 0 to 100 percent sweep (loops up and back down) so the shimmer
                    can be watched across every fill level, in particular the low-fill ramp,
                    without running a real job. -->
                    <ProgressBar Maximum="100" Foreground="{DynamicResource AccentBrush}">
                        <ProgressBar.Styles>
                            <Style Selector="ProgressBar">
                                <Style.Animations>
                                    <Animation IterationCount="Infinite"
                                               Duration="0:0:8"
                                               PlaybackDirection="Alternate">
                                        <KeyFrame Cue="0%">
                                            <Setter Property="Value" Value="0" />
                                        </KeyFrame>
                                        <KeyFrame Cue="100%">
                                            <Setter Property="Value" Value="100" />
                                        </KeyFrame>
                                    </Animation>
                                </Style.Animations>
                            </Style>
                        </ProgressBar.Styles>
                    </ProgressBar>
                    <ProgressBar IsIndeterminate="True" Foreground="{DynamicResource AccentBrush}" />

                    <!-- Accent / status / category swatches -->
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Border Width="44" Height="22" CornerRadius="4" Background="{DynamicResource AccentBrush}" />
                        <Border Width="44" Height="22" CornerRadius="4" Background="{DynamicResource SuccessBrush}" />
                        <Border Width="44" Height="22" CornerRadius="4" Background="{DynamicResource ErrorBrush}" />
                        <Border Width="44" Height="22" CornerRadius="4" Background="{DynamicResource CategoryVocalsBrush}" />
                        <Border Width="44" Height="22" CornerRadius="4" Background="{DynamicResource CategoryInstrumentalsBrush}" />
                        <Border Width="44" Height="22" CornerRadius="4" Background="{DynamicResource CategoryOtherBrush}" />
                    </StackPanel>

                </StackPanel>
            </Border>
        </Border>
    </Design.PreviewWith>

    <!-- Base window background -->
    <Style Selector="Window">
        <Setter Property="Background" Value="{DynamicResource Bg1Brush}" />
        <Setter Property="FontFamily" Value="{DynamicResource UiFont}" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    </Style>

    <!-- TextBox selection highlight covers full input width, not just text extent -->
    <Style Selector="TextBox /template/ TextPresenter#PART_TextPresenter">
        <Setter Property="HorizontalAlignment" Value="Stretch" />
    </Style>

    <!-- Heading: toolbar titles (15px / 600) -->
    <Style Selector="TextBlock.h1">
        <Setter Property="FontSize" Value="15" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    </Style>

    <!-- Section label (11px / 700 uppercase, tracking) -->
    <Style Selector="TextBlock.sectionLabel">
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{DynamicResource TextPlaceholderBrush}" />
        <Setter Property="LetterSpacing" Value="0.07" />
    </Style>

    <!-- Mono body -->
    <Style Selector="TextBlock.mono">
        <Setter Property="FontFamily" Value="{DynamicResource MonoFont}" />
    </Style>
    <Style Selector="SelectableTextBlock.mono">
        <Setter Property="FontFamily" Value="{DynamicResource MonoFont}" />
    </Style>

    <!-- Secondary text -->
    <Style Selector="TextBlock.secondary">
        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
    </Style>

    <!-- Accent (amber) button: primary CTA -->
    <Style Selector="Button.accent">
        <Setter Property="Foreground" Value="White" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="CornerRadius" Value="{DynamicResource RadiusButton}" />
        <Setter Property="Padding" Value="14,8" />
        <Setter Property="BorderThickness" Value="0" />
    </Style>
    <Style Selector="Button.accent /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
    </Style>
    <Style Selector="Button.accent:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource AccentBrightBrush}" />
    </Style>
    <Style Selector="Button.accent:disabled /template/ ContentPresenter">
        <Setter Property="Opacity" Value="0.4" />
    </Style>

    <!-- Ghost button: secondary -->
    <Style Selector="Button.ghost">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Bg3Brush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{DynamicResource RadiusButton}" />
        <Setter Property="Padding" Value="12,6" />
        <Setter Property="FontSize" Value="12" />
    </Style>
    <Style Selector="Button.ghost:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource Bg2Brush}" />
        <Setter Property="TextBlock.Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    </Style>

    <!-- Info icon: small "ⓘ" affordance signalling that an element has a hover tooltip.
    See docs/adr/0001-info-icon-tooltip-affordance.md. Attach ToolTip.Tip on the icon.
    Style does NOT set Text on a descendant TextBlock — call sites inline the "i"
    glyph so the style can't accidentally match (and override) the TextBlock that
    ToolTip.Tip uses as its content.
    Background MUST be Transparent (not null/unset) so the inner disc participates
    in hit testing — otherwise only the 1px ring and the "i" glyph trigger hovers. -->
    <Style Selector="Border.infoIcon">
        <Setter Property="Width" Value="14" />
        <Setter Property="Height" Value="14" />
        <Setter Property="CornerRadius" Value="7" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="{DynamicResource TextSecondaryBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Cursor" Value="Help" />
    </Style>
    <Style Selector="Border.infoIcon:pointerover">
        <Setter Property="BorderBrush" Value="{DynamicResource TextPrimaryBrush}" />
    </Style>

</Styles>
